# 环境配置示例
# 复制此文件为 .env 并修改相应配置

# ── 网关 ─────────────────────────────────────────────────
# API 网关监听端口
PORT=8000

# ── 下游服务地址（网关用）────────────────────────────────
# game-engine 服务地址
GAME_ENGINE_URL=http://localhost:8001
# ai-engine 服务地址
AI_ENGINE_URL=http://localhost:8002

# ── CORS（网关用）───────────────────────────────────────
# 允许的前端 Origin，逗号分隔
# Docker 环境示例：http://frontend:5173,http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── 前端 ─────────────────────────────────────────────────
# 前端请求的网关地址（Vite 构建时注入）
VITE_API_URL=http://localhost:8000

# ── 数据库（game-engine 用）──────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./database/sqlite/game.db

# ── ChromaDB（ai-engine 用）──────────────────────────────
CHROMADB_PATH=./database/chromadb

# ── 模型（ai-engine 用）──────────────────────────────────
# LLM 模型文件路径（GGUF 格式）
LLM_MODEL_PATH=./models/llm/llama-3-8b-instruct.q4_k_m.gguf
# 嵌入模型名称（HuggingFace）
EMBEDDING_MODEL=all-MiniLM-L6-v2
