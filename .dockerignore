# AI-RPG Engine Docker Ignore
# 忽略不需要打包进Docker镜像的文件和目录

# Git
.git
.gitignore
.gitattributes

# Python
__pycache__
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
ENV/
*.egg-info
dist/
build/
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn-integrity

# Go
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
go.work

# 模型文件（需要单独挂载）
models/llm/*.gguf
models/embeddings/
models/rerankers/

# 数据库文件（需要单独挂载）
database/sqlite/*.db
database/sqlite/*.db-journal
database/chromadb/

# RAG数据（受限制）
data-core/vectors/
data-core/indexes/

# 日志文件
logs/
*.log

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# 环境配置
.env
.env.local
.env.*.local

# 测试
tests/
coverage/
.nyc_output/

# 文档
docs/*.md
!docs/architecture.md
!docs/api-spec.md
*.pdf

# 其他
*.bak
*.tmp
*.temp
.cache
Thumbs.db
