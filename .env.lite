# AI-RPG Engine Lite 模式配置
# 适用于低配置环境，大幅降低资源需求

# ===========================================
# 基础配置
# ===========================================
PORT=8000
LOG_LEVEL=INFO

# ===========================================
# 数据库配置
# ===========================================
DATABASE_URL=sqlite+aiosqlite:///./database/sqlite/game.db
CHROMADB_PATH=./database/chromadb

# ===========================================
# LLM 模型配置 - Lite 优化
# ===========================================
# 使用小型 LLM 模型（推荐 Qwen-1.8B-Chat 或 Phi-2）
# 文件大小: ~1-2GB
LLM_MODEL_PATH=./models/llm/qwen-1.8b-chat-q4_k_m.gguf

# LLM 推理参数优化
LLM_MAX_TOKENS=512
LLM_TEMPERATURE=0.7
LLM_TOP_P=0.9
LLM_N_CTX=2048
LLM_N_GPU_LAYERS=0

# ===========================================
# 嵌入模型配置 - Lite 优化
# ===========================================
# 使用小型嵌入模型
# 模型大小: ~80MB
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_MAX_SEQ_LENGTH=256
EMBEDDING_BATCH_SIZE=32

# ===========================================
# 重排序模型配置 - Lite 禁用
# ===========================================
# 禁用重排序以节省内存（节省约 1-2GB）
DISABLE_RERANKER=true

# 如果启用，使用轻量级模型
# RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ===========================================
# RAG 配置 - Lite 优化
# ===========================================
# 减少检索数量
RAG_TOP_K=3
RAG_RERANK_TOP_K=0

# 更小的块大小
CHUNK_SIZE=256
CHUNK_OVERLAP=50

# ===========================================
# 服务 URL
# ===========================================
GAME_ENGINE_URL=http://localhost:8001
AI_ENGINE_URL=http://localhost:8002

# ===========================================
# 前端 API URL
# ===========================================
VITE_API_URL=http://localhost:8000

# ===========================================
# Lite 模式标记
# ===========================================
LITE_MODE=true

# ===========================================
# 性能优化
# ===========================================
# 启用模型缓存
ENABLE_MODEL_CACHE=true

# 批处理优化
BATCH_INFERENCE=true
MAX_BATCH_SIZE=8

# 内存优化
ENABLE_MEMORY_OPTIMIZATION=true
MAX_MEMORY_USAGE_GB=4

# ===========================================
# 可选：使用外部 API
# ===========================================
# 如果本地资源不足，可以使用外部 API
# USE_OPENAI_API=true
# OPENAI_API_KEY=your-api-key
# OPENAI_MODEL=gpt-3.5-turbo
